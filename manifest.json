  "presentations": [
    {
      "id": "spark-intro",
      "title": "Apache Spark: An Introduction",
      "topic": "apache-spark",
      "pages": [
        {
          "id": "what-is-spark",
          "sceneId": "spark-cluster",
          "slide": {
            "title": "What is Apache Spark?",
            "bullets": [
              "A unified engine for large-scale data processing",
              "In-memory computation makes it fast",
              "APIs in Scala, Python, Java and R"
            ]
          },
          "narration": {
            "text": "Apache Spark is a unified analytics engine for large-scale data processing."
          }
        },
        {
          "id": "the-driver",
          "sceneId": "spark-cluster",
          "slide": {
            "title": "The Driver",
            "bullets": [
              "Hosts the SparkContext / SparkSession",
              "Builds the DAG and schedules tasks",
              "The 'brain' of your application"
            ]
          },
          "overrides": { "highlightNodeIds": ["driver"] }
        },
        {
          "id": "the-executors",
          "sceneId": "spark-cluster",
          "slide": {
            "title": "Executors on Workers",
            "bullets": [
              "Run the actual tasks in parallel",
              "Hold data partitions in memory",
              "Report results back to the driver"
            ]
          },
          "overrides": { "highlightNodeIds": ["w1", "w2", "w3"] }
        },
        {
          "id": "rdd-lineage",
          "sceneId": "spark-rdd-lineage",
          "slide": {
            "title": "RDD Lineage (Word Count)",
            "bullets": [
              "Transformations are lazy — they build a lineage",
              "An action (e.g. collect) triggers execution",
              "Lineage enables fault recovery by recomputation"
            ],
            "code": {
              "language": "scala",
              "source": "sc.textFile(\"in.txt\")\n  .flatMap(_.split(\" \"))\n  .map((_, 1))\n  .reduceByKey(_ + _)"
            }
          }
        }
      ]
    }
